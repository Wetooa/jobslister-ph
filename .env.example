# Copy to `.env` and set secrets. Docker Compose loads `.env` via `env_file`.
# For local Next.js dev, prefer `.env.local` (same variable names).

ADMIN_PASSWORD=changeme

# Ollama (optional)
# Docker Compose: the `ollama` service reads this for cloud models (default `gemma4:31b-cloud`).
# Create a key at https://ollama.com/settings/keys — without it, cloud inference returns 401.
# OLLAMA_API_KEY=

# When the app runs in Docker and Ollama is on the host instead:
# OLLAMA_HOST=http://host.docker.internal:11434
# Or full URL:
# OLLAMA_API_URL=http://host.docker.internal:11434/api/generate
# OLLAMA_MODEL=your-model-name
